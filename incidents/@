@login_required
def change_status(request, pk, new_status):
    incident = get_object_or_404(Incident, pk=pk)

    allowed_transitions = {
        "OPEN": ["ASSIGNED"],
        "ASSIGNED": ["IN_PROGRESS"],
        "IN_PROGRESS": ["RESOLVED"],
        "RESOLVED": ["CLOSED"],
        "CLOSED": []
    }

    # Check if transition is valid
    if new_status not in allowed_transitions.get(incident.status, []):
        return HttpResponseForbidden("Invalid status transition.")

    # Role Rules
    if new_status == "ASSIGNED":
        if request.user.role not in ["MANAGER", "ADMIN"]:
            return HttpResponseForbidden("Only Manager/Admin can assign.")
        incident.assigned_to = request.user

    if new_status == "CLOSED":
        if request.user.role != "ADMIN":
            return HttpResponseForbidden("Only Admin can close incident.")

    # ✅ STORE OLD STATUS BEFORE CHANGING
    old_status = incident.status

    # ✅ UPDATE STATUS
    incident.status = new_status
    incident.save()

    # ✅ CREATE AUDIT LOG ENTRY
    IncidentLog.objects.create(
        incident=incident,
        changed_by=request.user,
        old_status=old_status,
        new_status=new_status
    )

    return redirect("incident_list")
